{"nodes": [{"id": "docs_superpowers_specs_2026_07_03_lolarr_home_browse_design_lolarr_slice_2_home_browse", "label": "Lolarr Slice 2: Home/Browse (Design)", "file_type": "document", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-home-browse-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_media_item_jellyfin_extension", "label": "MediaItem.jellyfin sub-object (Approach A)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-home-browse-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Chosen approach: one MediaItem type with an optional jellyfin sub-object rather than a discriminated union or type split, keeping Discover (TMDB) and Library (Jellyfin) items unified under one schema."}, {"id": "code_apps_api_get_api_home", "label": "GET /api/home endpoint", "file_type": "code", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-home-browse-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "code_apps_api_get_api_library_itemid", "label": "GET /api/library/:itemId endpoint", "file_type": "code", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-home-browse-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "code_packages_jellyfin", "label": "packages/jellyfin (client image-URL builder)", "file_type": "code", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-home-browse-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_home_degradation_strategy", "label": "Home Degradation Strategy (Promise.allSettled row-wise)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-home-browse-design.md", "source_lo