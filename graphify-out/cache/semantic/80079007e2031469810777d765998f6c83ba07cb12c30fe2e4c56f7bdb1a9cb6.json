{"nodes": [{"id": "docs_superpowers_specs_2026_07_03_lolarr_foundation_auth_design_lolarr_slice_1_fundament_auth", "label": "Lolarr Slice 1: Fundament + Auth (Design)", "file_type": "document", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_lolarr_hybrid_bff_architecture", "label": "Lolarr Hybrid-BFF Architecture", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Metadata/Auth/Seerr traffic goes through apps/api (Fastify); images and video streams go client-direct to Jellyfin later, so the BFF never becomes a media-proxy bottleneck."}, {"id": "concept_jellyfin_server", "label": "Jellyfin (media server)", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_seerr_server", "label": "Seerr (request management server)", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_wholphin_reference_client", "label": "Wholphin (Android TV reference client)", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_moonfin_reference_client", "label": "Moonfin (Tizen/webOS reference client)", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "code_apps_api", "label": "apps/api (Fastify BFF)", "file_type": "code", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "code_packages_domain", "label": "packages/domain", "file_type": "code", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "code_packages_features", "label": "packages/features", "file_type": "code", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "code_packages_ui", "label": "packages/ui", "file_type": "code", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_demo_mode_removal", "label": "Demo-Mode Removal", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Demo data/fallbacks (demoUser, demoRows, findDemoItem, searchDemoItems) are removed entirely; API must fail fast at startup without required config, so there is exactly one code path and no risk of silently serving fake data in production."}, {"id": "concept_password_login_flow", "label": "Password Login Flow (Web)", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_quick_connect_login_flow", "label": "Quick Connect Login Flow (TV)", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_silent_quick_connect", "label": "Silent Quick Connect (Seerr session renewal)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Whenever the Seerr session is missing/expired (401) and a valid Jellyfin token exists, the BFF re-authenticates transparently via Seerr's QuickConnect endpoints and the user's stored Jellyfin token \u2014 avoiding admin-key impersonation and giving a single Seerr auth path for both QC-login and cookie renewal."}, {"id": "concept_401_cascade", "label": "401-Kaskade (session invalidation cascade)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "If the Jellyfin token itself is invalid (e.g. admin revoke), the BFF ends the Lolarr session and forces the client back to login; a Seerr 401 instead triggers Silent-QC renewal first, only cascading to logout if that also fails."}, {"id": "concept_seerr_api_key_scoping", "label": "SEERR_API_KEY scoping (admin key vs per-user session)", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "SEERR_API_KEY is used only for cacheable, user-independent reads (discover/search/media-details); writes (create/delete requests) always go through the per-user Seerr session, preventing the admin key from being used to impersonate users."}], "edges": [{"source": "docs_superpowers_specs_2026_07_03_lolarr_foundation_auth_design_lolarr_slice_1_fundament_auth", "target": "concept_lolarr_hybrid_bff_architecture", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "weight": 1.0}, {"source": "concept_lolarr_hybrid_bff_architecture", "target": "code_apps_api", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "weight": 1.0}, {"source": "code_apps_api", "target": "concept_jellyfin_server", "relation": "calls", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "weight": 1.0}, {"source": "code_apps_api", "target": "concept_seerr_server", "relation": "calls", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_2026_07_03_lolarr_foundation_auth_design_lolarr_slice_1_fundament_auth", "target": "concept_wholphin_reference_client", "relation": "cites", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_2026_07_03_lolarr_foundation_auth_design_lolarr_slice_1_fundament_auth", "target": "concept_moonfin_reference_client", "relation": "cites", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-03-lolarr-foundation-auth-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_2026_07_03_lolarr_foundat