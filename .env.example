SEERR_API_KEY=replace-with-seerr-api-key
LOLARR_SECRET=replace-with-at-least-16-characters
LOLARR_WEBHOOK_SECRET=replace-with-at-least-16-characters
LOLARR_DATABASE_PATH=./data/lolarr.sqlite
