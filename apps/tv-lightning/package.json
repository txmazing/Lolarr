{
  "name": "@lolarr/tv-lightning",
  "version": "0.0.1",
  "private": true,
  "description": "An app template using @plextv/react-lightning",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:tizen": "vite build --config vite.tizen.config.ts",
    "clean": "del ./dist",
    "dev": "vite --host 0.0.0.0",
    "preview": "vite preview --host",
    "check:types": "tsc --noEmit",
    "test:unit": "vitest run --passWithNoTests",
    "tizen:sync": "pnpm run build:tizen && rm -rf tizen/assets tizen/fonts && cp -R dist-tizen/assets tizen/assets && cp -R public/fonts tizen/fonts"
  },
  "dependencies": {
    "@lightningjs/renderer": "3.0.1",
    "@plextv/react-lightning": "0.4.2",
    "@plextv/react-lightning-components": "0.4.2",
    "@plextv/react-lightning-plugin-css-transform": "0.4.2",
    "@plextv/react-lightning-plugin-flexbox": "0.4.2",
    "@plextv/react-native-lightning": "0.4.2",
    "@tanstack/react-query": "^5.101.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@plextv/vite-plugin-msdf-fontgen": "1.3.4",
    "@plextv/vite-plugin-react-native-lightning": "0.4.3",
    "@rolldown/plugin-babel": "0.2.3",
    "@tsconfig/vite-react": "7.0.2",
    "@types/node": "25.0.9",
    "@types/react": "19.2.8",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "del-cli": "7.0.0",
    "vite": "8.1.3"
  },
  "packageManager": "pnpm@10.12.3"
}
